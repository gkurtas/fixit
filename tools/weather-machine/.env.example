# Copy this file to ".env" and paste your key after the = sign.
#   cp .env.example .env
# The real .env is gitignored and never committed. The LOCAL dev runner
# (pipeline/run_local.py) reads it automatically. Production does NOT use a key
# at all - the Lambda authenticates to Claude through Amazon Bedrock via its IAM
# role, so there is nothing to store or rotate in AWS.

ANTHROPIC_API_KEY=

# Optional: shown to NWS as your contact in the request User-Agent.
# CONTACT_EMAIL=weather-machine@inquirer.com
